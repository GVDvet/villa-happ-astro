{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/checkout/create/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/checkout/webhook/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/newsletter/?$",
			"dest": "_render"
		},
		{
			"src": "^/brands/?$",
			"dest": "_render"
		},
		{
			"src": "^/cart/?$",
			"dest": "_render"
		},
		{
			"src": "^/drops/?$",
			"dest": "_render"
		},
		{
			"src": "^/journal/?$",
			"dest": "_render"
		},
		{
			"src": "^/shop/?$",
			"dest": "_render"
		},
		{
			"src": "^/story/?$",
			"dest": "_render"
		},
		{
			"src": "^/wishlist/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	],
	"images": {
		"sizes": [
			640,
			750,
			828,
			1080,
			1200,
			1920,
			2048,
			3840
		],
		"domains": [],
		"remotePatterns": []
	}
}