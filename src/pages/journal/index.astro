---
export const prerender = true;

import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Pic from '../../components/Pic.astro';
import '../../styles/shop.css';

const posts = (await getCollection('journal')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Base
  title="Journal · Villa Happ"
  description="Verhalen, achtergronden en het leven achter het label. Over drie generaties Tilburgs vakmanschap, drops en materiaal."
>
  <section class="vh-page">
    <div class="vh-page-inner">

      <header class="vh-page-head">
        <p class="vh-page-label vh-mono">Journal · Het leven achter het label</p>
        <h1 class="vh-page-title">Verhalen die <span class="vh-italic-accent">blijven</span></h1>
        <p class="vh-page-sub">Over drie generaties, genummerde oplages en spullen die je doorgeeft.</p>
      </header>

      <div class="vh-journal-grid">
        {posts.map((post) => (
          <article class="vh-journal-card">
            {post.data.image && (
              <a href={`/journal/${post.id}`} class="vh-journal-media" tabindex="-1" aria-hidden="true">
                <Pic src={post.data.image} alt="" width={600} height={400} sizes="(max-width: 700px) 90vw, 30vw" loading="lazy" />
              </a>
            )}
            <div class="vh-journal-body">
              <p class="vh-mono vh-journal-date">{fmt(post.data.date)}</p>
              <h2><a href={`/journal/${post.id}`}>{post.data.title}</a></h2>
              <p class="vh-journal-desc">{post.data.description}</p>
              <a class="vh-journal-more" href={`/journal/${post.id}`}>Lees verder →</a>
            </div>
          </article>
        ))}
      </div>

    </div>
  </section>

  <style>
    .vh-journal-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }
    .vh-journal-card {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--vh-line, rgba(30, 30, 27, 0.14));
      background: rgba(255, 255, 255, 0.35);
    }
    .vh-journal-media { display: block; overflow: hidden; aspect-ratio: 3 / 2; }
    .vh-journal-media img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .vh-journal-card:hover .vh-journal-media img { transform: scale(1.04); }
    .vh-journal-body { padding: 20px 22px 24px; display: flex; flex-direction: column; gap: 10px; }
    .vh-journal-date { font-size: 11px; opacity: 0.55; margin: 0; }
    .vh-journal-body h2 { font-family: var(--vh-font-serif); font-size: 22px; line-height: 1.25; margin: 0; }
    .vh-journal-body h2 a { text-decoration: none; color: inherit; }
    .vh-journal-body h2 a:hover { text-decoration: underline; text-underline-offset: 4px; }
    .vh-journal-desc { font-size: 14px; line-height: 1.65; opacity: 0.75; margin: 0; }
    .vh-journal-more {
      font-family: var(--vh-font-mono);
      font-size: 12px;
      margin-top: auto;
      text-decoration: none;
      color: inherit;
    }
    .vh-journal-more:hover { text-decoration: underline; text-underline-offset: 4px; }
    @media (max-width: 900px) {
      .vh-journal-grid { grid-template-columns: 1fr; max-width: 560px; margin: 0 auto; }
    }
  </style>
</Base>

<script>import '../../lib/cart';</script>
