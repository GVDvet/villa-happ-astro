---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import '../../styles/shop.css';
---
<Base title="Bedankt · Villa Happ" noindex={true}>
  <section class="vh-page">
    <div class="vh-result">
      <div class="vh-result-stamp">
        <b>Welkom in het archief</b>
        <span>Est. 1960 · Tilburg</span>
      </div>
      <h1>Je frame is <span class="vh-italic-accent">vastgelegd</span>.</h1>
      <p>
        Bedankt voor je bestelling. Je ontvangt een bevestiging per e-mail
        zodra de betaling is verwerkt.
        <br /><br />
        <span class="vh-result-ordernr" id="vh-ordernr"></span>
      </p>
      <div class="vh-result-actions">
        <a href="/shop" class="vh-btn vh-btn--primary"><span>Verder shoppen</span></a>
        <a href="/" class="vh-btn vh-btn--ghost"><span>Naar home</span></a>
      </div>
    </div>
  </section>
</Base>

<script>
  import { clearCart } from '../../lib/cart';

  // Mandje leegmaken: de bestelling is geplaatst.
  clearCart();

  const nr = new URLSearchParams(window.location.search).get('order');
  if (nr) document.getElementById('vh-ordernr')!.textContent = `Bestelnummer · ${nr}`;
</script>
