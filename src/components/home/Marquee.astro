---
const items = [
  '65 jaar craftsmanship',
  'Limited edition drops',
  'Made with care · Tilburg',
  'Free shipping NL · BE · DE',
  'H_APProved brands',
  'Premium materials',
];
// Dupliceer voor seamless loop
const trackItems = [...items, ...items];
---

<aside class="vh-marquee" aria-label="Villa Happ kernwaarden">
  <div class="vh-marquee-track">
    {trackItems.map(text => (
      <span class="vh-marquee-item">
        <span class="vh-marquee-dot" aria-hidden="true"></span>
        {text}
      </span>
    ))}
  </div>
</aside>

<style>
  .vh-marquee {
    background: var(--vh-ink);
    color: var(--vh-paper);
    padding: 18px 0;
    overflow: hidden;
    border-top: 1px solid rgba(247, 243, 236, 0.06);
    border-bottom: 1px solid rgba(247, 243, 236, 0.06);
    position: relative;
    z-index: 10;
  }

  .vh-marquee-track {
    display: flex;
    gap: 56px;
    animation: vh-marquee 32s linear infinite;
    width: max-content;
    will-change: transform;
  }

  .vh-marquee:hover .vh-marquee-track {
    animation-play-state: paused;
  }

  .vh-marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    font-size: 13px;
    letter-spacing: var(--vh-tracking-wider);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .vh-marquee-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--vh-accent);
    flex-shrink: 0;
  }

  @keyframes vh-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .vh-marquee-track { animation: none; }
  }
</style>
