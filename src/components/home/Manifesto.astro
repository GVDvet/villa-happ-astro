---
// Manifesto met word-by-word fill on scroll + inline foto's in de zin (fctrylab-stijl)
const text = "Twee keer gevallen. Drie keer opgestaan. Wij maken stukken met een verhaal, gedragen door de generatie van toen, en die van nu.";
const accentWords = new Set(['opgestaan.', 'verhaal', 'generatie', 'nu.']);
const inlineAfter: Record<string, string> = {
  'verhaal,': '/img/products/hoodie-logo-detail.webp',
  'generatie': '/img/heritage/origin-babyparadijs.webp',
};
const words = text.split(' ');
---
<section class="vh-manifesto">
  <div class="vh-manifesto-inner">
    <p class="vh-manifesto-label vh-mono">01 / Manifest</p>
    <p class="vh-manifesto-text">
      {words.map((w) => {
        const clean = w.replace(/[.,]/g, '');
        const isAccent = accentWords.has(w) || accentWords.has(clean);
        const inlineImg = inlineAfter[w];
        return (
          <>
            <span class={`vh-word${isAccent ? ' vh-word-accent' : ''}`}>{w} </span>
            {inlineImg && (
              <span class="vh-inline-img"><img src={inlineImg} alt="" loading="lazy" /></span>
            )}
            {inlineImg && ' '}
          </>
        );
      })}
    </p>
  </div>
</section>
