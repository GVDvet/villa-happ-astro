---
import Hero3D from '../3d/Hero3D.tsx';
---

<section class="vh-scene vh-scene--hero" data-scene="1" data-bg="#1A1A18" data-text="#F7F3EC">

  <!-- 3D island (hybrid: subtle 3D background) -->
  <div class="vh-hero-3d">
    <Hero3D client:load />
  </div>

  <!-- Ambient blobs -->
  <div class="vh-ambient vh-ambient--accent" style="width:380px; height:380px; top:15%; right:-80px;" aria-hidden="true"></div>
  <div class="vh-ambient vh-ambient--olive" style="width:280px; height:280px; bottom:20%; left:-60px;" aria-hidden="true"></div>

  <div class="vh-hero-content">
    <p class="vh-hero-kicker vh-anim">65 jaar Villa Happ</p>

    <h1 class="vh-hero-title" data-vh-italic="familieverhaal,mode-erfgoed,erfgoed">
      <span class="vh-split-line"><span>Van familieverhaal</span></span>
      <span class="vh-split-line"><span>naar mode-erfgoed.</span></span>
    </h1>

    <p class="vh-hero-sub vh-anim">
      Klaar voor een nieuwe generatie dragers.
    </p>

    <div class="vh-hero-cta-group vh-anim">
      <a href="/shop" class="vh-btn vh-btn--light" data-vh-magnetic="0.2">
        <span>Ontdek de collectie</span>
        <svg class="vh-btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
      <a href="/drops" class="vh-btn vh-btn--ghost">
        <span>Bekijk drops</span>
      </a>
    </div>
  </div>

  <!-- Stats bar -->
  <div class="vh-hero-stats" aria-hidden="true">
    <div class="vh-hero-stat">
      <span class="vh-hero-stat-num"><span data-vh-counter="65">0</span></span>
      <span class="vh-hero-stat-label">Jaar craft</span>
    </div>
    <div class="vh-hero-stat">
      <span class="vh-hero-stat-num"><span data-vh-counter="80">0</span></span>
      <span class="vh-hero-stat-label">Winkels in Europa</span>
    </div>
    <div class="vh-hero-stat">
      <span class="vh-hero-stat-num"><span data-vh-counter="3">0</span></span>
      <span class="vh-hero-stat-label">Generaties</span>
    </div>
  </div>

  <div class="vh-scroll-indicator" aria-hidden="true">
    <span class="vh-scroll-indicator-line"></span>
    <span class="vh-scroll-indicator-text">Scroll</span>
  </div>

</section>
