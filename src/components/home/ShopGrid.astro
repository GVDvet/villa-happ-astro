---
import { getFeaturedProducts, formatPrice } from '../../lib/commerce';

const dbProducts = await getFeaturedProducts(6);

// Fallback editorial products (echte Hoodie afbeeldingen)
const fallback = [
  { slug: 'heritage-hoodie-grey', name: 'Heritage Hoodie', price_cents: 12900, image_url: '/img/products/hoodie-grey-front.png', hover_url: '/img/products/hoodie-grey-back.png', badge: 'Nieuw', meta: 'Heather Grey · Unisex' },
  { slug: 'heritage-hoodie-blue', name: 'Heritage Hoodie', price_cents: 12900, image_url: '/img/products/hoodie-blue-front.png', hover_url: '/img/products/hoodie-blue-lifestyle.png', badge: null, meta: 'Tilburg Blue · Unisex' },
  { slug: 'heritage-hoodie-lifestyle', name: 'Heritage Hoodie', price_cents: 12900, image_url: '/img/products/hoodie-grey-lifestyle.png', hover_url: '/img/products/hoodie-grey-new2.png', badge: 'Bestseller', meta: 'Heather Grey · Oversized' },
];

const products = dbProducts.length > 0
  ? dbProducts.map((p) => ({
      slug: p.slug, name: p.name, price_cents: p.price_cents,
      image_url: p.image_url || '/img/products/hoodie-grey-front.png',
      hover_url: (p.gallery && p.gallery[0]) || p.image_url || '/img/products/hoodie-grey-back.png',
      badge: p.compare_at_cents ? 'Sale' : (p.featured ? 'Featured' : null),
      meta: p.category || '',
    }))
  : fallback;
---
<section class="vh-shop">
  <div class="vh-shop-inner">
    <div class="vh-shop-header vh-reveal">
      <div>
        <p class="vh-shop-eyebrow">De collectie</p>
        <h2 class="vh-shop-title">Nu te dragen</h2>
      </div>
      <a href="/shop" class="vh-shop-link">
        Bekijk alles
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    <div class="vh-shop-grid">
      {products.map((p, i) => (
        <a href={`/shop/${p.slug}`} class="vh-shop-card vh-reveal" style={`transition-delay: ${(i % 3) * 0.1}s;`}>
          <div class="vh-shop-card-media">
            {p.badge && <span class="vh-shop-card-badge">{p.badge}</span>}
            <button class="vh-shop-card-wishlist" type="button" aria-label="Voeg toe aan wishlist" data-wishlist={p.slug}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
              </svg>
            </button>
            <img src={p.image_url} alt={p.name} class="vh-shop-card-img is-primary" width="600" height="750" loading="lazy" />
            <img src={p.hover_url} alt="" class="vh-shop-card-img is-hover" width="600" height="750" loading="lazy" aria-hidden="true" />
            <button class="vh-shop-card-quick" type="button" data-quick-add={p.slug}>Snel toevoegen</button>
          </div>
          <div class="vh-shop-card-info">
            <p class="vh-shop-card-name">{p.name}</p>
            <p class="vh-shop-card-price">{formatPrice(p.price_cents)}</p>
          </div>
          {p.meta && <p class="vh-shop-card-meta">{p.meta}</p>}
        </a>
      ))}
    </div>
  </div>
</section>
