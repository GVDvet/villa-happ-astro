---
const stats = [
  { number: 65, suffix: '+', label: 'Jaar van craftsmanship sinds onze start in 1960.' },
  { number: 80, suffix: '', label: 'Winkels in Europa op het hoogtepunt van groei.' },
  { number: 3, suffix: '', label: 'Generaties die hetzelfde verhaal blijven doorvertellen.' },
];
---

<section class="vh-stats-scene-outro" aria-label="Villa Happ in cijfers">
  <div class="vh-container">
    <p class="vh-stats-eyebrow">In cijfers</p>
    <div class="vh-stats-grid">
      {stats.map(stat => (
        <div class="vh-stat-cell">
          <p class="vh-stat-num-big">
            <span data-vh-counter={stat.number} data-vh-duration="2000">0</span>{stat.suffix && <span class="vh-stat-suffix">{stat.suffix}</span>}
          </p>
          <p class="vh-stat-label-big">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .vh-stats-scene-outro {
    padding: clamp(80px, 12vw, 160px) 0;
    background: var(--vh-paper);
    color: var(--vh-ink);
    position: relative;
    z-index: 5;
  }

  .vh-stats-eyebrow {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: var(--vh-tracking-widest);
    color: var(--vh-ink-muted);
    margin: 0 0 32px;
  }

  .vh-stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(32px, 5vw, 80px);
    align-items: end;
  }

  .vh-stat-cell {
    border-top: 1px solid var(--vh-ink-faint);
    padding-top: 24px;
  }

  .vh-stat-num-big {
    font-family: var(--vh-font-serif);
    font-size: clamp(60px, 10vw, 160px);
    line-height: 0.95;
    font-weight: 300;
    letter-spacing: var(--vh-tracking-tighter);
    margin: 0 0 12px;
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .vh-stat-suffix {
    font-size: 0.4em;
    color: var(--vh-accent);
    font-style: italic;
  }

  .vh-stat-label-big {
    font-size: 13px;
    color: var(--vh-ink-soft);
    margin: 0;
    max-width: 220px;
    line-height: 1.5;
  }

  @media (max-width: 800px) {
    .vh-stats-grid { grid-template-columns: 1fr; gap: 36px; }
  }
</style>
