---
// Editorial split hero — bold type links, full-bleed lifestyle foto rechts
---
<section class="vh-hero" id="vh-hero">
  <div class="vh-hero-text">
    <span class="vh-hero-kicker">Sinds 1960 · Tilburg</span>

    <h1 class="vh-hero-title">
      <span class="vh-hero-title-line"><span class="vh-hero-title-word">Heritage,</span></span>
      <span class="vh-hero-title-line"><span class="vh-hero-title-word vh-italic-accent">gedragen</span></span>
      <span class="vh-hero-title-line"><span class="vh-hero-title-word">nu.</span></span>
    </h1>

    <p class="vh-hero-sub">
      Een Nederlands lifestylelabel met 65 jaar verhaal. Limited edition drops,
      gemaakt met dezelfde toewijding als waarmee het begon.
    </p>

    <div class="vh-hero-actions">
      <a href="/shop" class="vh-btn vh-btn--primary" data-magnetic>
        <span>Shop de collectie</span>
        <svg class="vh-btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
      <a href="/drops" class="vh-btn vh-btn--ghost"><span>Bekijk drops</span></a>
    </div>

    <div class="vh-hero-stats">
      <div class="vh-hero-stat">
        <span class="vh-hero-stat-num" data-count="65">65</span>
        <span class="vh-hero-stat-label">Jaar craft</span>
      </div>
      <div class="vh-hero-stat">
        <span class="vh-hero-stat-num" data-count="80">80</span>
        <span class="vh-hero-stat-label">Winkels in Europa</span>
      </div>
      <div class="vh-hero-stat">
        <span class="vh-hero-stat-num" data-count="3">3</span>
        <span class="vh-hero-stat-label">Generaties</span>
      </div>
    </div>
  </div>

  <div class="vh-hero-media">
    <span class="vh-hero-tag">Drop 001 · Live binnenkort</span>
    <img
      src="/img/products/hoodie-grey-lifestyle.png"
      alt="Villa Happ Heritage Hoodie, gedragen"
      class="vh-hero-media-img"
      width="1200" height="1500"
      fetchpriority="high"
    />
  </div>

  <span class="vh-hero-scroll">Scroll</span>
</section>
