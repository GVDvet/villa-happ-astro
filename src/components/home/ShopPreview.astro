---
import { getFeaturedProducts } from '../../lib/commerce';
const products = await getFeaturedProducts(3);
---

<section class="vh-shop-preview-scene" aria-label="Nu in de shop">
  <div class="vh-container">

    <header class="vh-shop-preview-header">
      <div>
        <p class="vh-shop-preview-eyebrow">Nu in de shop</p>
        <h2 class="vh-shop-preview-title" data-vh-italic="dragers,nieuwe">
          Voor de nieuwe dragers
        </h2>
      </div>
      <a href="/shop" class="vh-shop-preview-link">
        Bekijk de hele collectie
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </header>

    {products.length > 0 ? (
      <div class="vh-shop-preview-grid">
        {products.map(product => (
          <a href={`/shop/${product.slug}`} class="vh-shop-preview-card">
            <div class="vh-shop-preview-img">
              {product.image_url
                ? <img src={product.image_url} alt={product.name} loading="lazy" />
                : <div class="vh-img-placeholder"></div>
              }
            </div>
            <div class="vh-shop-preview-meta">
              <p class="vh-shop-preview-name">{product.name}</p>
              <p class="vh-shop-preview-price">€ {(product.price_cents / 100).toFixed(2)}</p>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="vh-shop-preview-grid">
        <!-- Placeholders als Supabase niet geconnect is -->
        <div class="vh-shop-preview-card">
          <div class="vh-shop-preview-img"><img src="/img/products/hoodie-grey-front.png" alt="Heritage Hoodie Grey" /></div>
          <div class="vh-shop-preview-meta">
            <p class="vh-shop-preview-name">Heritage Hoodie Grey</p>
            <p class="vh-shop-preview-price">€ 129,00</p>
          </div>
        </div>
        <div class="vh-shop-preview-card">
          <div class="vh-shop-preview-img"><img src="/img/products/hoodie-blue-front.png" alt="Heritage Hoodie Blue" /></div>
          <div class="vh-shop-preview-meta">
            <p class="vh-shop-preview-name">Heritage Hoodie Blue</p>
            <p class="vh-shop-preview-price">€ 129,00</p>
          </div>
        </div>
        <div class="vh-shop-preview-card">
          <div class="vh-shop-preview-img"><img src="/img/products/hoodie-grey-lifestyle.png" alt="Heritage Hoodie Lifestyle" /></div>
          <div class="vh-shop-preview-meta">
            <p class="vh-shop-preview-name">Heritage Hoodie Unisex</p>
            <p class="vh-shop-preview-price">€ 129,00</p>
          </div>
        </div>
      </div>
    )}

  </div>
</section>

<style>
  .vh-shop-preview-scene {
    padding: clamp(80px, 12vw, 140px) 0;
    background: var(--vh-white);
    color: var(--vh-ink);
    position: relative;
    z-index: 5;
  }

  .vh-shop-preview-header {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 32px;
    margin-bottom: 48px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--vh-ink-hairline);
  }

  .vh-shop-preview-eyebrow {
    font-size: 11px;
    letter-spacing: var(--vh-tracking-widest);
    text-transform: uppercase;
    color: var(--vh-ink-muted);
    margin: 0 0 12px;
  }

  .vh-shop-preview-title {
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 400;
    letter-spacing: var(--vh-tracking-tight);
    line-height: 1.05;
    margin: 0;
  }

  .vh-shop-preview-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    letter-spacing: var(--vh-tracking-wide);
    color: var(--vh-ink);
    border-bottom: 1px solid var(--vh-ink-faint);
    padding-bottom: 4px;
    transition: all var(--vh-dur-fast) ease;
    white-space: nowrap;
  }

  .vh-shop-preview-link:hover {
    border-bottom-color: var(--vh-ink);
    color: var(--vh-accent);
  }

  .vh-shop-preview-link svg { transition: transform var(--vh-dur-base) var(--vh-ease-out); }
  .vh-shop-preview-link:hover svg { transform: translateX(4px); }

  .vh-shop-preview-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .vh-shop-preview-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .vh-shop-preview-img {
    width: 100%;
    aspect-ratio: 3/4;
    background: var(--vh-paper);
    border-radius: var(--vh-radius-md);
    overflow: hidden;
    margin-bottom: 16px;
  }

  .vh-shop-preview-img img,
  .vh-img-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--vh-ease-out);
  }

  .vh-shop-preview-card:hover .vh-shop-preview-img img {
    transform: scale(1.04);
  }

  .vh-shop-preview-name {
    font-size: 14px;
    font-weight: 500;
    margin: 0 0 4px;
  }

  .vh-shop-preview-price {
    font-size: 13px;
    color: var(--vh-ink-soft);
    margin: 0;
  }

  @media (max-width: 800px) {
    .vh-shop-preview-header { grid-template-columns: 1fr; gap: 16px; }
    .vh-shop-preview-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
  }
  @media (max-width: 500px) {
    .vh-shop-preview-grid { grid-template-columns: 1fr; }
  }
</style>
