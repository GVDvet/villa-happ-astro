---
// Globale cart drawer — client-rendered vanuit localStorage.
// Open via window event 'vh:open-cart' (header-icoon, add-to-cart).
---
<div class="vh-drawer" id="vh-drawer" aria-hidden="true">
  <button type="button" class="vh-drawer-overlay" data-drawer-close aria-label="Sluit winkelmandje"></button>

  <aside class="vh-drawer-panel" role="dialog" aria-label="Winkelmandje" tabindex="-1">
    <header class="vh-drawer-head">
      <p class="vh-drawer-title">Winkelmandje <span class="vh-drawer-count vh-mono" data-drawer-count></span></p>
      <button type="button" class="vh-drawer-close" data-drawer-close aria-label="Sluiten">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none"><path d="M5 5l10 10M15 5L5 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </header>

    <div class="vh-drawer-shipbar" data-drawer-shipbar></div>

    <div class="vh-drawer-body" data-drawer-body></div>

    <footer class="vh-drawer-foot" data-drawer-foot></footer>
  </aside>
</div>

<div class="vh-toast vh-mono" id="vh-toast" role="status" aria-live="polite"></div>

<style>
  .vh-drawer { position: fixed; inset: 0; z-index: 8000; visibility: hidden; pointer-events: none; }
  .vh-drawer.is-open { visibility: visible; pointer-events: auto; }

  .vh-drawer-overlay {
    position: absolute; inset: 0;
    background: rgba(28, 24, 19, 0);
    border: 0; cursor: pointer; padding: 0;
    transition: background 0.4s ease;
  }
  .vh-drawer.is-open .vh-drawer-overlay { background: rgba(28, 24, 19, 0.55); }

  .vh-drawer-panel {
    position: absolute; top: 0; right: 0; bottom: 0;
    width: min(440px, 100vw);
    background: var(--vh-paper);
    color: var(--vh-ink);
    display: flex; flex-direction: column;
    transform: translateX(102%);
    transition: transform 0.5s var(--vh-ease-out);
    box-shadow: -16px 0 48px rgba(28, 24, 19, 0.18);
    outline: none;
  }
  .vh-drawer.is-open .vh-drawer-panel { transform: translateX(0); }

  .vh-drawer-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 22px 24px 18px;
    border-bottom: 1px solid var(--vh-ink-hairline);
  }
  .vh-drawer-title {
    margin: 0;
    font-family: var(--vh-font-serif);
    font-size: 22px;
  }
  .vh-drawer-count { font-size: 11px; color: var(--vh-ink-muted); margin-left: 6px; }
  .vh-drawer-close {
    background: none; border: 0; cursor: pointer; color: var(--vh-ink);
    width: 34px; height: 34px; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    transition: background var(--vh-dur-fast) ease;
  }
  .vh-drawer-close:hover { background: var(--vh-ink-hairline); }

  /* Gratis verzending balk */
  .vh-drawer-shipbar { padding: 0 24px; }
  .vh-drawer-shipbar:not(:empty) {
    padding: 14px 24px;
    background: var(--vh-paper-soft);
    border-bottom: 1px solid var(--vh-ink-hairline);
    font-size: 12px;
  }
  .vh-drawer-shipbar .bar {
    height: 3px; background: var(--vh-ink-faint);
    border-radius: 99px; overflow: hidden; margin-top: 8px;
  }
  .vh-drawer-shipbar .bar span {
    display: block; height: 100%;
    background: var(--vh-accent);
    border-radius: 99px;
    transition: width 0.5s var(--vh-ease-out);
  }

  .vh-drawer-body { flex: 1; overflow-y: auto; }

  .vh-drawer-empty { padding: 70px 24px; text-align: center; }
  .vh-drawer-empty p {
    font-family: var(--vh-font-serif); font-style: italic;
    font-size: 20px; color: var(--vh-ink-muted); margin: 0 0 22px;
  }

  .vh-drawer-item {
    display: grid;
    grid-template-columns: 76px 1fr auto;
    gap: 14px;
    padding: 18px 24px;
    border-bottom: 1px solid var(--vh-ink-hairline);
    align-items: start;
  }
  .vh-drawer-item img {
    width: 76px; height: 95px; object-fit: cover;
    border-radius: var(--vh-radius-sm);
    background: var(--vh-paper-soft);
  }
  .vh-drawer-item-name { font-size: 14px; font-weight: 500; margin: 0 0 2px; }
  .vh-drawer-item-variant {
    font-family: var(--vh-font-mono); font-size: 10px;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--vh-ink-muted); margin: 0 0 10px;
  }
  .vh-drawer-qty {
    display: inline-flex; align-items: center; gap: 0;
    border: 1px solid var(--vh-ink-faint); border-radius: 99px;
  }
  .vh-drawer-qty button {
    width: 28px; height: 28px; border: 0; background: none;
    cursor: pointer; font-size: 14px; color: var(--vh-ink);
    transition: color var(--vh-dur-fast) ease;
  }
  .vh-drawer-qty button:hover { color: var(--vh-accent); }
  .vh-drawer-qty b { font-size: 12px; min-width: 22px; text-align: center; font-weight: 500; }
  .vh-drawer-item-right { display: flex; flex-direction: column; align-items: flex-end; gap: 10px; }
  .vh-drawer-item-price { font-family: var(--vh-font-serif); font-size: 16px; margin: 0; }
  .vh-drawer-item-remove {
    background: none; border: 0; cursor: pointer;
    font-family: var(--vh-font-mono); font-size: 10px;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--vh-ink-muted); padding: 2px;
    transition: color var(--vh-dur-fast) ease;
  }
  .vh-drawer-item-remove:hover { color: var(--vh-danger); }

  .vh-drawer-foot:not(:empty) {
    padding: 18px 24px 24px;
    border-top: 1px solid var(--vh-ink-hairline);
    background: var(--vh-paper);
  }
  .vh-drawer-subtotal {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 6px;
  }
  .vh-drawer-subtotal span {
    font-family: var(--vh-font-mono); font-size: 10px;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--vh-ink-muted);
  }
  .vh-drawer-subtotal b { font-family: var(--vh-font-serif); font-size: 22px; font-weight: 500; }
  .vh-drawer-foot small {
    display: block; font-size: 11px; color: var(--vh-ink-muted); margin-bottom: 14px;
  }
  .vh-drawer-actions { display: grid; gap: 10px; }

  /* Toast */
  .vh-toast {
    position: fixed;
    left: 50%; bottom: 26px;
    transform: translate(-50%, 16px);
    background: var(--vh-ink); color: var(--vh-paper);
    padding: 11px 20px;
    border-radius: 99px;
    font-size: 11px;
    z-index: 9000;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s ease, transform 0.4s var(--vh-ease-out);
  }
  .vh-toast.is-visible { opacity: 1; transform: translate(-50%, 0); }
</style>

<script>
  import { getCart, updateQuantity, removeFromCart, cartSubtotal, cartCount, onCartChange, shippingCostCents, FREE_SHIPPING_CENTS } from '../../lib/cart';

  const drawer = document.getElementById('vh-drawer')!;
  const panel = drawer.querySelector('.vh-drawer-panel') as HTMLElement;
  const body = drawer.querySelector('[data-drawer-body]') as HTMLElement;
  const foot = drawer.querySelector('[data-drawer-foot]') as HTMLElement;
  const shipbar = drawer.querySelector('[data-drawer-shipbar]') as HTMLElement;
  const countEl = drawer.querySelector('[data-drawer-count]') as HTMLElement;
  const toast = document.getElementById('vh-toast')!;

  const eur = (c: number) => '€ ' + (c / 100).toFixed(2).replace('.', ',');
  let lastFocus: HTMLElement | null = null;
  let toastTimer: ReturnType<typeof setTimeout>;

  function showToast(msg: string) {
    toast.textContent = msg;
    toast.classList.add('is-visible');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('is-visible'), 2400);
  }

  function render() {
    const items = getCart();
    countEl.textContent = items.length ? `(${cartCount()})` : '';

    if (!items.length) {
      shipbar.innerHTML = '';
      foot.innerHTML = '';
      body.innerHTML = `
        <div class="vh-drawer-empty">
          <p>Je mandje is nog leeg.</p>
          <a href="/shop" class="vh-btn vh-btn--primary"><span>Ontdek de collectie</span></a>
        </div>`;
      return;
    }

    const subtotal = cartSubtotal();

    // Gratis verzending voortgang
    if (subtotal >= FREE_SHIPPING_CENTS) {
      shipbar.innerHTML = `Je hebt <b>gratis verzending</b> ✦<div class="bar"><span style="width:100%"></span></div>`;
    } else {
      const left = FREE_SHIPPING_CENTS - subtotal;
      const pct = Math.min(100, (subtotal / FREE_SHIPPING_CENTS) * 100);
      shipbar.innerHTML = `Nog <b>${eur(left)}</b> tot gratis verzending<div class="bar"><span style="width:${pct}%"></span></div>`;
    }

    body.innerHTML = items.map((i) => `
      <div class="vh-drawer-item" data-vid="${i.variant_id}">
        <a href="/shop/${i.slug}"><img src="${i.image_url || ''}" alt="" loading="lazy" /></a>
        <div>
          <p class="vh-drawer-item-name">${i.name}</p>
          <p class="vh-drawer-item-variant">${i.variant_label || ''}</p>
          <span class="vh-drawer-qty">
            <button type="button" data-dec aria-label="Minder">−</button>
            <b>${i.quantity}</b>
            <button type="button" data-inc aria-label="Meer">+</button>
          </span>
        </div>
        <div class="vh-drawer-item-right">
          <p class="vh-drawer-item-price">${eur(i.unit_price_cents * i.quantity)}</p>
          <button type="button" class="vh-drawer-item-remove" data-remove>Verwijder</button>
        </div>
      </div>`).join('');

    foot.innerHTML = `
      <div class="vh-drawer-subtotal"><span>Subtotaal</span><b>${eur(subtotal)}</b></div>
      <small>Verzendkosten berekend bij het afrekenen · NL gratis vanaf € 75</small>
      <div class="vh-drawer-actions">
        <a href="/checkout" class="vh-btn vh-btn--accent"><span>Afrekenen</span>
          <svg class="vh-btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/cart" class="vh-btn vh-btn--ghost"><span>Bekijk winkelmandje</span></a>
      </div>`;
  }

  function open() {
    lastFocus = document.activeElement as HTMLElement;
    render();
    drawer.classList.add('is-open');
    drawer.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    setTimeout(() => panel.focus(), 60);
  }

  function close() {
    drawer.classList.remove('is-open');
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    lastFocus?.focus();
  }

  window.addEventListener('vh:open-cart', open);
  window.addEventListener('vh:toast', ((e: CustomEvent) => showToast(e.detail)) as EventListener);
  drawer.querySelectorAll('[data-drawer-close]').forEach((b) => b.addEventListener('click', close));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer.classList.contains('is-open')) close();
  });

  // Item-acties (event delegation)
  body.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const row = target.closest('[data-vid]') as HTMLElement | null;
    if (!row) return;
    const vid = row.dataset.vid!;
    const item = getCart().find((i) => i.variant_id === vid);
    if (!item) return;
    if (target.closest('[data-inc]')) updateQuantity(vid, item.quantity + 1);
    else if (target.closest('[data-dec]')) updateQuantity(vid, item.quantity - 1);
    else if (target.closest('[data-remove]')) removeFromCart(vid);
  });

  onCartChange(() => { if (drawer.classList.contains('is-open')) render(); });
</script>
