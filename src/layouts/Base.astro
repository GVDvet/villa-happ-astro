---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CartDrawer from '../components/commerce/CartDrawer.astro';
import { isPreviewHost } from '../lib/site';
import '../styles/tokens.css';
import '../styles/base.css';
import '../styles/buttons.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  bodyClass?: string;
  showHeader?: boolean;
  showFooter?: boolean;
  noindex?: boolean;
}

const {
  title = 'Villa Happ · Heritage lifestyle, gemaakt voor nu',
  description = 'Nederlands lifestylelabel sinds 1960. Van familieverhaal naar mode-erfgoed. Limited edition drops en gecureerde merken uit Tilburg.',
  ogImage = '/img/products/hoodie-grey-lifestyle.webp',
  bodyClass = '',
  showHeader = true,
  showFooter = true,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
// Social platforms vereisen een absolute og:image-URL
const ogImageAbs = new URL(ogImage, canonicalURL).toString();
// Preview-omgeving (*.vercel.app) mag nooit de index in
const preview = isPreviewHost(canonicalURL.origin);
---

<!doctype html>
<html lang="nl" class="no-js">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Space+Mono&display=swap"
  />
  <link rel="preload" as="image" href="/img/products/hoodie-grey-lifestyle.webp" fetchpriority="high" />
  <script is:inline>document.documentElement.classList.remove('no-js');</script>
  <script is:inline>
  // Diagnose: vangt de eerste JS-fout; met ?vh-debug in de URL verschijnt
  // een statusoverlay (build, reduce-motion, pins, scrollY, fouten).
  (function () {
    window.addEventListener('error', function (e) {
      if (!window.__vhErr) window.__vhErr = (e.message || 'script error') + ' @ ' + String(e.filename || '').split('/').pop() + ':' + e.lineno;
    });
    window.addEventListener('unhandledrejection', function (e) {
      if (!window.__vhErr) window.__vhErr = 'promise: ' + e.reason;
    });
    if (location.search.indexOf('vh-debug') === -1) return;
    function start() {
      var d = document.createElement('div');
      d.style.cssText = 'position:fixed;bottom:10px;left:10px;right:10px;z-index:99999;background:rgba(0,0,0,.85);color:#7CFC00;font:11px/1.6 monospace;padding:10px 12px;border-radius:8px;pointer-events:none;white-space:pre-wrap;';
      document.body.appendChild(d);
      setInterval(function () {
        var meta = document.querySelector('meta[name="vh-build"]');
        var red = matchMedia('(prefers-reduced-motion: reduce)').matches;
        d.textContent =
          'build ' + (meta ? meta.getAttribute('content') : '?') +
          ' | ' + innerWidth + 'x' + innerHeight +
          ' | scrollY ' + Math.round(scrollY) +
          '\nreduce-motion: ' + (red ? 'AAN, site staat bewust op statisch' : 'uit') +
          ' | pins: ' + document.querySelectorAll('.pin-spacer').length +
          ' | motion: ' + (window.__vhMotion ? 'gestart' : 'NIET GESTART') +
          '\nfout: ' + (window.__vhErr || 'geen');
      }, 400);
    }
    if (document.body) start(); else addEventListener('DOMContentLoaded', start);
  })();
  </script>

  <title>{title}</title>
  <meta name="description" content={description} />
  {(noindex || preview) && <meta name="robots" content="noindex, follow" />}
  <meta name="vh-build" content={(process.env.VERCEL_GIT_COMMIT_SHA || 'local').slice(0, 7)} />
  <link rel="canonical" href={canonicalURL.toString()} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageAbs} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL.toString()} />
  <meta property="og:site_name" content="Villa Happ" />
  <meta property="og:locale" content="nl_NL" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={ogImageAbs} />

  <meta name="theme-color" content="#F7F3EC" />

  <!-- JSON-LD: Organization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Villa Happ',
    url: canonicalURL.origin,
    logo: `${canonicalURL.origin}/img/brand/villa-happ-logo.webp`,
    description: 'Nederlands lifestylelabel sinds 1960.',
    foundingDate: '1960',
    foundingLocation: { '@type': 'Place', name: 'Tilburg, Nederland' },
  })}></script>
</head>

<body class={`vh-body ${bodyClass}`}>
  <a class="vh-skip-link" href="#main-content">Ga naar inhoud</a>

  <!-- Page transition wipe -->
  <div class="vh-wipe" id="vh-wipe" aria-hidden="true">
    <span class="vh-wipe-mark">Villa Happ</span>
  </div>

  {showHeader && <Header />}

  <main id="main-content">
    <slot />
  </main>

  {showFooter && <Footer />}

  <CartDrawer />

  <style>
    .vh-wipe {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: var(--vh-espresso);
      display: flex;
      align-items: center;
      justify-content: center;
      transform: scaleY(0);
      transform-origin: bottom;
      pointer-events: none;
    }
    .vh-wipe.cover {
      transform: scaleY(1);
      transform-origin: bottom;
      transition: transform 0.55s cubic-bezier(0.76, 0, 0.24, 1);
      pointer-events: all;
    }
    .vh-wipe.cover-instant {
      transform: scaleY(1);
      transform-origin: top;
      transition: none;
    }
    .vh-wipe.reveal {
      transform: scaleY(0);
      transform-origin: top;
      transition: transform 0.55s cubic-bezier(0.76, 0, 0.24, 1);
    }
    .vh-wipe-mark {
      font-family: var(--vh-font-serif);
      font-style: italic;
      font-size: clamp(28px, 4vw, 48px);
      color: var(--vh-paper);
      opacity: 0;
      transform: translateY(10px);
    }
    .vh-wipe.cover .vh-wipe-mark,
    .vh-wipe.cover-instant .vh-wipe-mark {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 0.4s ease 0.1s, transform 0.4s ease 0.1s;
    }
    @media (prefers-reduced-motion: reduce) {
      .vh-wipe { display: none; }
    }
  </style>

  <script is:inline>
    (function () {
      var wipe = document.getElementById('vh-wipe');
      if (!wipe) return;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Reveal bij binnenkomst (alleen na interne navigatie)
      if (!reduce && sessionStorage.getItem('vh-nav')) {
        sessionStorage.removeItem('vh-nav');
        wipe.classList.add('cover-instant');
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            wipe.classList.remove('cover-instant');
            wipe.classList.add('reveal');
            setTimeout(function () { wipe.classList.remove('reveal'); }, 600);
          });
        });
      }

      // Cover bij interne link-klik
      document.addEventListener('click', function (e) {
        if (reduce) return;
        var a = e.target.closest && e.target.closest('a');
        if (!a) return;
        if (a.hasAttribute('data-no-wipe')) return;
        var href = a.getAttribute('href');
        if (!href || href.charAt(0) === '#' || a.target === '_blank') return;
        if (href.indexOf('http') === 0 && href.indexOf(window.location.origin) !== 0) return;
        if (href.indexOf('mailto:') === 0 || href.indexOf('tel:') === 0) return;
        if (e.metaKey || e.ctrlKey || e.shiftKey || e.button !== 0) return;
        // Zelfde pagina? niets doen
        var url = new URL(href, window.location.href);
        if (url.pathname === window.location.pathname) return;

        e.preventDefault();
        sessionStorage.setItem('vh-nav', '1');
        wipe.classList.add('cover');
        setTimeout(function () { window.location.href = url.href; }, 560);
      });

      // Bij terug-knop (bfcache) reset wipe
      window.addEventListener('pageshow', function (ev) {
        if (ev.persisted) { wipe.className = 'vh-wipe'; }
      });
    })();
  </script>
</body>
</html>
